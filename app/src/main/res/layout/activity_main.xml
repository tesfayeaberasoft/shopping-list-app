<?xml version="1.0" encoding="utf-8"?>
<!-- MainActivity Layout - Main Shopping Lists Screen
     Displays RecyclerView of shopping lists with FAB for creating new lists
     
     Layout Components:
     - CoordinatorLayout: Main container with coordination behavior
     - RecyclerView: Shopping lists display with smooth scrolling
     - FloatingActionButton: Create new list action
     - TextView: Empty state message
     - Material Design: Modern UI components
     
     Layout Structure:
     - Root: CoordinatorLayout (match_parent)
     - Child 1: RecyclerView (shopping lists)
     - Child 2: FloatingActionButton (create list)
     - Child 3: TextView (empty state)
     
     Responsive Design:
     - Adapts to all screen sizes
     - Supports landscape and portrait
     - Optimized for tablets
     - Flexible margins and padding
     - Scalable text sizes
     
     Accessibility:
     - Content descriptions for buttons
     - Semantic structure
     - Keyboard navigation
     - Screen reader support
     - High contrast support
     - Focus indicators
     
     Material Design 3:
     - Modern color scheme
     - Smooth animations
     - Elevation and shadows
     - Ripple effects
     - Typography hierarchy
     
     RecyclerView Configuration:
     - LinearLayoutManager (vertical)
     - Item animations
     - Smooth scrolling
     - Efficient rendering
     - Memory optimization
     
     FloatingActionButton:
     - Create new list action
     - Prominent placement
     - Ripple effect
     - Accessibility label
     - Keyboard shortcut
     
     Empty State:
     - Displayed when no lists exist
     - Helpful message
     - Call-to-action
     - Visual indicator
     
     Performance:
     - Efficient layout inflation
     - Optimized rendering
     - Smooth scrolling
     - Memory efficient
     - Fast interactions
     
     Theming:
     - Light mode support
     - Dark mode support
     - System theme support
     - Custom colors
     - Dynamic theming
     
     Animations:
     - Item insertion
     - Item removal
     - Smooth transitions
     - FAB animation
     - Scroll behavior
     
     Testing:
     - Layout validation
     - Responsive testing
     - Accessibility testing
     - Performance testing
     - Device compatibility
     
     Future Enhancements:
     - Swipe to delete
     - Drag to reorder
     - Search functionality
     - Filter options
     - Sort options
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_lists"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:background="?android:attr/colorBackground"/>

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/no_lists"
        android:textSize="@dimen/text_size_large"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone" />

    <!-- Square FAB with Label -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fab_add_list"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/colorPrimary"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    android:contentDescription="@string/create_list"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/create_list_short"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:maxLines="2" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>