<?xml version="1.0" encoding="utf-8"?>
<!-- Fade In Animation - Used for smooth UI transitions
     Provides fade effect for activity and fragment transitions
     
     Animation Properties:
     - Duration: 800ms (fade effect)
     - Start Offset: 500ms (delay before animation)
     - Effect: Fade in from transparent (0.0) to opaque (1.0)
     - Used for: Activity transitions, Fragment animations, View reveals
     - Timing: Linear interpolation (default)
     
     Animation Sequence:
     1. Wait 500ms (startOffset)
     2. Fade in over 800ms
     3. Total time: 1300ms
     
     Alpha Values:
     - fromAlpha: 0.0 (fully transparent)
     - toAlpha: 1.0 (fully opaque)
     - Smooth gradient between values
     
     Use Cases:
     - Activity entrance animation
     - Fragment transition
     - View reveal animation
     - Dialog appearance
     - Splash screen fade
     - Content loading animation
     
     Performance:
     - Hardware accelerated
     - Smooth 60fps animation
     - Optimized for all devices
     - Minimal CPU usage
     - GPU rendering
     - Battery efficient
     
     Compatibility:
     - All Android versions
     - All screen sizes
     - All devices
     - Landscape and portrait
     - Tablets and phones
     
     Best Practices:
     - Use for screen transitions
     - Combine with other animations
     - Test on low-end devices
     - Avoid excessive animations
     - Keep duration reasonable
     - Consider accessibility
     
     Accessibility:
     - Respects animation preferences
     - Can be disabled by users
     - Doesn't interfere with navigation
     - Provides visual feedback
     - Smooth transitions
     
     Customization:
     - Adjust duration for different effects
     - Change startOffset for timing
     - Combine with scale/translate
     - Use with interpolators
     - Create animation sets
     
     Related Animations:
     - Fade out (reverse effect)
     - Slide in (combined with fade)
     - Scale in (combined with fade)
     - Rotate in (combined with fade)
     
     Testing:
     - Visual inspection
     - Performance profiling
     - Device compatibility
     - Accessibility testing
     - Animation smoothness
     
     Optimization:
     - Use hardware acceleration
     - Minimize animation complexity
     - Avoid nested animations
     - Profile on target devices
     - Monitor frame rate
     
     Future Enhancements:
     - Configurable duration
     - Custom interpolators
     - Animation presets
     - User preferences
     - Dynamic timing
-->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <alpha
        android:duration="800"
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:startOffset="500" />
</set>
